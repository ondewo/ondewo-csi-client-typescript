# ONDEWO CSI TypeScript SDK — example configuration template.
#
# Loaded by each runnable example via dotenv (path resolved relative to the
# script, so the current working directory does not matter).
#
# This file is a TEMPLATE and contains NO real secrets — it is safe to commit.
# Fill in the blank secret values locally; never commit real credentials.

# --- Connection to the ONDEWO CSI server (gRPC-web endpoint) ---
ONDEWO_HOST=localhost
ONDEWO_PORT=50055
# Use a TLS (https) gRPC-web channel when true, plaintext (http) when false.
ONDEWO_USE_SECURE_CHANNEL=false

# --- Keycloak authentication (OIDC resource-owner password login) ---
KEYCLOAK_URL=https://localhost:8443/auth
KEYCLOAK_REALM=ondewo
KEYCLOAK_CLIENT_ID=ondewo-nlu-cai-sdk-public
KEYCLOAK_USER_NAME=
KEYCLOAK_PASSWORD=
# Verify the Keycloak TLS certificate; set false only for self-signed local setups.
KEYCLOAK_VERIFY_SSL=true
